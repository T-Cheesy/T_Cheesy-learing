<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Offline AI Tutor with Image Recognition</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .chatbox-container {
            width: 100%;
            max-width: 700px;
            height: 90vh;
            max-height: 800px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            text-align: center;
            font-size: 24px;
            font-weight: bold;
            border-bottom: 2px solid rgba(0, 0, 0, 0.1);
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
        }

        .header-title {
            flex: 1;
            text-align: center;
        }

        .header-info {
            position: absolute;
            right: 20px;
            font-size: 12px;
            background: rgba(255,255,255,0.2);
            padding: 5px 10px;
            border-radius: 4px;
        }

        .messages {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .message {
            display: flex;
            margin-bottom: 10px;
            animation: slideIn 0.3s ease-out;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .message.user {
            justify-content: flex-end;
        }

        .message.ai {
            justify-content: flex-start;
        }

        .message-content {
            max-width: 70%;
            padding: 12px 16px;
            border-radius: 12px;
            word-wrap: break-word;
            line-height: 1.5;
            font-size: 14px;
        }

        .message.user .message-content {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-bottom-right-radius: 4px;
        }

        .message.ai .message-content {
            background: #f0f0f0;
            color: #333;
            border-bottom-left-radius: 4px;
        }

        .message-image {
            max-width: 100%;
            max-height: 300px;
            border-radius: 8px;
            margin-top: 8px;
        }

        .loading {
            display: flex;
            gap: 4px;
            align-items: center;
            padding: 12px 16px;
        }

        .loading span {
            width: 8px;
            height: 8px;
            background: #667eea;
            border-radius: 50%;
            animation: bounce 1.4s infinite;
        }

        .loading span:nth-child(2) {
            animation-delay: 0.2s;
        }

        .loading span:nth-child(3) {
            animation-delay: 0.4s;
        }

        @keyframes bounce {
            0%, 60%, 100% {
                transform: translateY(0);
            }
            30% {
                transform: translateY(-10px);
            }
        }

        .input-area {
            border-top: 1px solid #e0e0e0;
            padding: 16px;
            display: flex;
            gap: 10px;
            background: white;
            flex-wrap: wrap;
            align-items: flex-end;
        }

        .input-group {
            display: flex;
            gap: 10px;
            flex: 1;
            min-width: 250px;
        }

        .input-area input[type="text"] {
            flex: 1;
            border: 1px solid #ddd;
            border-radius: 24px;
            padding: 12px 16px;
            font-size: 14px;
            outline: none;
            transition: border-color 0.2s;
        }

        .input-area input[type="text"]:focus {
            border-color: #667eea;
        }

        .input-area input[type="file"] {
            display: none;
        }

        .send-btn, .upload-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            transition: transform 0.2s;
        }

        .send-btn:hover, .upload-btn:hover {
            transform: scale(1.05);
        }

        .send-btn:active, .upload-btn:active {
            transform: scale(0.95);
        }

        .example-topics {
            padding: 15px 20px;
            background: #f9f9f9;
            border-top: 1px solid #e0e0e0;
            font-size: 12px;
            color: #666;
            text-align: center;
            max-height: 100px;
            overflow-y: auto;
        }

        .example-topics strong {
            display: block;
            margin-bottom: 8px;
            color: #333;
        }

        .topic-tags {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .topic-tags span {
            background: white;
            padding: 4px 12px;
            border-radius: 12px;
            border: 1px solid #ddd;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 12px;
        }

        .topic-tags span:hover {
            background: #667eea;
            color: white;
            border-color: #667eea;
        }

        .upload-preview {
            width: 50px;
            height: 50px;
            border-radius: 8px;
            object-fit: cover;
            border: 2px solid #ddd;
        }

        .preview-container {
            position: relative;
            display: inline-block;
        }

        .preview-remove {
            position: absolute;
            top: -8px;
            right: -8px;
            background: #d32f2f;
            color: white;
            border: none;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            cursor: pointer;
            font-size: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body>
    <div class="chatbox-container">
        <div class="header">
            <div class="header-title">📚 AI Tutor</div>
            <div class="header-info">📱 Offline + 📸 Images</div>
        </div>
        
        <div id="messagesContainer" class="messages">
            <div class="message ai">
                <div class="message-content">
                    👋 Hi! I'm your offline AI tutor with image recognition!
                    <br><br>
                    You can:
                    <br>📖 Ask about Chinese History & Math
                    <br>📸 Upload images of math problems or historical items
                    <br>🔍 I'll analyze images and answer questions
                    <br><br>
                    What would you like to learn about?
                </div>
            </div>
        </div>
        
        <div class="example-topics">
            <strong>Try:</strong>
            <div class="topic-tags">
                <span onclick="askQuestion('Tell me about the Ming Dynasty')">Ming Dynasty</span>
                <span onclick="askQuestion('What is calculus?')">Calculus</span>
                <span onclick="askQuestion('Upload a math problem image')">Math Photo</span>
            </div>
        </div>
        
        <div class="input-area">
            <div class="input-group">
                <button class="upload-btn" id="uploadBtn" title="Upload image">📸</button>
                <input type="file" id="imageInput" accept="image/*">
                <div id="previewContainer"></div>
                <input 
                    type="text" 
                    id="userInput" 
                    placeholder="Ask me anything or describe the image..." 
                    autocomplete="off"
                >
                <button class="send-btn" id="sendBtn">➤</button>
            </div>
        </div>
    </div>

    <script>
        // Knowledge Base
        const knowledgeBase = {
            history: {
                'ming dynasty': {
                    keywords: ['ming', 'dynasty', 'ming dynasty'],
                    response: `The Ming Dynasty (1368-1644) was one of China's greatest periods of cultural and artistic achievement. Key points:\n\n• Founded by Zhu Yuanzhang after the fall of the Yuan Dynasty\n• Known for the Forbidden City and the Great Wall renovations\n• Significant advancements in art, literature, and porcelain\n• Zheng He led massive maritime expeditions\n• Declined due to political instability and Manchu invasions\n\nThe Ming era represents a golden age of Chinese civilization with remarkable architectural and artistic contributions.`
                },
                'great wall': {
                    keywords: ['great wall', 'wall of china', 'wall'],
                    response: `The Great Wall of China is one of the most iconic structures in human history.\n\n• Construction began in the 7th century BC, continued for centuries\n• Primary purpose: Defense against northern invasions (Mongols, Xiongnu)\n• Length: Over 13,000 miles (21,000 km) including all branches\n• Built by millions of workers over centuries\n• Most famous sections built during the Ming Dynasty (1368-1644)\n• Used watchtowers, garrison stations, and beacon towers\n• Symbol of Chinese civilization and military engineering\n\nToday it's one of the most visited tourist attractions in the world.`
                },
                'forbidden city': {
                    keywords: ['forbidden city', 'emperor palace', 'imperial palace'],
                    response: `The Forbidden City is the imperial palace of Chinese emperors.\n\n• Located in Beijing, center of the city\n• Built in 1406 during the Ming Dynasty\n• Construction took 14 years with over 1 million workers\n• Covers 178 acres with 980 buildings\n• Named "Forbidden" because commoners were not allowed inside\n• Contains the throne hall and royal residences\n• Features traditional Chinese architecture at its finest\n• Contains over 1 million artifacts and artworks\n\nIt's now a UNESCO World Heritage Site and major museum.`
                },
                'tang dynasty': {
                    keywords: ['tang', 'tang dynasty'],
                    response: `The Tang Dynasty (618-907) was known as the "Golden Age" of Chinese civilization.\n\n• Period of greatest territorial expansion of Imperial China\n• Cultural peak with major developments in poetry, art, and music\n• Capital: Chang'an (modern-day Xi'an) - world's largest city at the time\n• Trade flourished along the Silk Road\n• Important poets like Li Bai and Du Fu lived during this era\n• Advances in technology, medicine, and government\n• Women had more rights and influence than in other dynasties\n• Decline due to internal conflicts and rebellions\n\nThe Tang Dynasty set the standard for later Chinese dynasties.`
                },
                'song dynasty': {
                    keywords: ['song', 'song dynasty'],
                    response: `The Song Dynasty (960-1279) was a period of remarkable technological and cultural advancement.\n\n• Divided into Northern Song (960-1127) and Southern Song (1127-1279)\n• Peak of landscape painting and ceramic arts\n• Invented printing, gunpowder weaponry, and navigation tools\n• Major philosophical developments including Neo-Confucianism\n• Economic prosperity with flourishing trade\n• Development of the first paper money system\n• Innovations in shipbuilding and maritime technology\n• Cultural achievements in poetry, calligraphy, and philosophy\n• Ended with Mongol invasion under Kublai Khan\n\nThe Song Dynasty represents one of humanity's greatest cultural achievements.`
                },
                'qin dynasty': {
                    keywords: ['qin', 'qin dynasty', 'qin shi huang', 'terra cotta'],
                    response: `The Qin Dynasty (221-206 BC) was the first unified Chinese empire.\n\n• Founded by Qin Shi Huang after conquering warring states\n• Extremely short but highly influential period\n• Created the Terracotta Army - 8,000+ life-sized soldiers\n• Built early sections of the Great Wall\n• Standardized measurements, currency, and writing systems\n• Connected roadways and established legal codes\n• Burned books and buried scholars to suppress dissent\n• Created the foundation for all future Chinese dynasties\n• Ended with civil unrest after Qin Shi Huang's death\n\nThough brief, the Qin Dynasty fundamentally shaped Chinese civilization.`
                },
                'silk road': {
                    keywords: ['silk road', 'trade route', 'silk'],
                    response: `The Silk Road was an extensive network of trade routes connecting East and West.\n\n• Primarily active from 2nd century BC to 15th century AD\n• Named after the valuable silk trade from China\n• Connected China, Central Asia, India, and the Mediterranean\n• Major goods traded: silk, spices, precious metals, ceramics\n• Also facilitated cultural, religious, and technological exchange\n• Buddhism spread to China along the Silk Road\n• Multiple routes both by land and sea\n• Mongol Empire in the 13th century expanded trade\n• Decline due to maritime route discoveries and political changes\n\nThe Silk Road shaped global trade and cultural interaction for centuries.`
                },
                'zheng he': {
                    keywords: ['zheng he', 'zheng', 'maritime', 'treasure voyage'],
                    response: `Zheng He was a famous Chinese admiral and explorer of the Ming Dynasty.\n\n• Lived 1371-1433, served under Emperor Yongle\n• Led seven major naval expeditions (1405-1433)\n• Commanded massive treasure fleets with 300+ ships\n• Voyages reached Africa, Arabia, and the Indian Ocean\n• Promoted trade and established diplomatic relations\n• Collected exotic animals and goods for the emperor\n• Demonstrated Chinese naval superiority\n• His voyages proved Chinese ships were superior to European ones\n• After his death, maritime exploration was abandoned\n\nZheng He's voyages remain among history's greatest expeditions.`
                },
                'confucius': {
                    keywords: ['confucius', 'confucianism', 'confucian'],
                    response: `Confucius (551-479 BC) was one of history's most influential philosophers.\n\n• Born during the Spring and Autumn Period\n• Focused on ethics, morality, and social relationships\n• Key concepts: Filial piety, respect for elders, social harmony\n• Believed in education and self-improvement\n• Emphasized the importance of ritual and tradition\n• His teachings were compiled in the Analects\n• Influenced Chinese government and culture for 2,500+ years\n• His philosophy spread to Korea, Japan, and Vietnam\n• Neo-Confucianism became dominant in Song Dynasty\n\nConfucian values continue to influence billions of people today.`
                }
            },
            math: {
                'algebra': {
                    keywords: ['algebra', 'equation', 'variable', 'solve'],
                    response: `Algebra is a branch of mathematics dealing with equations and variables.\n\n• Uses letters (variables) to represent unknown numbers\n• Core operations: addition, subtraction, multiplication, division\n• Key concepts:\n  - Linear equations: ax + b = c\n  - Quadratic equations: ax² + bx + c = 0\n  - Systems of equations with multiple variables\n  - Polynomials and factoring\n\n• Real-world applications: physics, engineering, economics\n• Problem-solving approach:\n  1. Identify the variable\n  2. Set up the equation\n  3. Isolate the variable using inverse operations\n  4. Check your solution\n\nAlgebra is fundamental to higher mathematics and science.`
                },
                'geometry': {
                    keywords: ['geometry', 'shape', 'triangle', 'circle', 'angle'],
                    response: `Geometry is the study of shapes, sizes, and spatial properties.\n\n• Key shapes:\n  - Triangles: three sides, angles sum to 180°\n  - Squares/Rectangles: four right angles, opposite sides equal\n  - Circles: all points equidistant from center\n  - Polygons: many-sided shapes\n\n• Important concepts:\n  - Area: space inside a shape\n  - Perimeter: distance around a shape\n  - Volume: space inside 3D objects\n  - Pythagorean theorem: a² + b² = c²\n\n• Common formulas:\n  - Triangle area = ½ × base × height\n  - Circle area = πr²\n  - Rectangle area = length × width\n\nGeometry connects to art, architecture, and engineering.`
                },
                'calculus': {
                    keywords: ['calculus', 'derivative', 'integral', 'limit'],
                    response: `Calculus is advanced mathematics studying change and motion.\n\n• Two main branches:\n  1. Differential Calculus - studying rates of change (derivatives)\n  2. Integral Calculus - studying accumulation and areas (integrals)\n\n• Key concepts:\n  - Limits: approaching a value\n  - Derivatives: rate of change, slope of curves\n  - Integrals: area under curves\n  - Functions: relationships between inputs and outputs\n\n• Real-world applications:\n  - Physics: motion, forces, energy\n  - Engineering: optimization, design\n  - Economics: cost and profit analysis\n  - Medicine: drug concentration in blood\n\n• Fundamental Theorem: derivatives and integrals are inverse operations\n\nCalculus is essential for science and engineering.`
                },
                'statistics': {
                    keywords: ['statistics', 'probability', 'data', 'average', 'mean'],
                    response: `Statistics is the study of data collection, analysis, and interpretation.\n\n• Key concepts:\n  - Mean: average of all values\n  - Median: middle value when ordered\n  - Mode: most frequently occurring value\n  - Range: difference between highest and lowest\n  - Standard deviation: measure of spread\n\n• Data types:\n  - Quantitative: numerical data\n  - Qualitative: categorical data\n  - Discrete: countable values\n  - Continuous: infinite possible values\n\n• Probability basics:\n  - Probability = favorable outcomes / total outcomes\n  - Values range from 0 (impossible) to 1 (certain)\n\n• Applications: surveys, research, business analysis, medicine\n\nStatistics helps understand and make sense of data.`
                },
                'trigonometry': {
                    keywords: ['trigonometry', 'sine', 'cosine', 'tangent', 'trig'],
                    response: `Trigonometry studies relationships between angles and sides in triangles.\n\n• Main functions (SOH-CAH-TOA):\n  - Sine = opposite / hypotenuse\n  - Cosine = adjacent / hypotenuse\n  - Tangent = opposite / adjacent\n\n• Key angles:\n  - 0°, 30°, 45°, 60°, 90° have standard values\n  - Angles measured in degrees or radians\n\n• Important identities:\n  - sin²θ + cos²θ = 1\n  - sin(2θ) = 2sinθcosθ\n\n• Applications:\n  - Navigation and surveying\n  - Architecture and engineering\n  - Physics (waves, oscillations)\n  - Computer graphics\n  - Astronomy\n\nTrigonometry connects geometry and circular motion.`
                },
                'fractions': {
                    keywords: ['fraction', 'numerator', 'denominator', 'simplify'],
                    response: `Fractions represent parts of a whole number.\n\n• Parts:\n  - Numerator: top number (how many parts)\n  - Denominator: bottom number (total parts)\n  - Example: 3/4 means 3 out of 4 parts\n\n• Operations:\n  - Addition/Subtraction: need same denominator\n  - Multiplication: multiply numerators and denominators\n  - Division: multiply by reciprocal\n\n• Simplifying:\n  - Divide both by common factors\n  - Example: 4/8 = 1/2 (divide by 4)\n\n• Types:\n  - Proper: numerator < denominator\n  - Improper: numerator > denominator\n  - Mixed: whole number + fraction\n\n• Converting:\n  - To decimal: divide numerator by denominator\n  - To percent: multiply decimal by 100\n\nFractions are fundamental to mathematics and cooking!`
                },
                'percentage': {
                    keywords: ['percentage', 'percent', '%', 'proportion'],
                    response: `Percentages express numbers as parts of 100.\n\n• Basic formula:\n  - Percentage = (part / whole) × 100\n  - Example: 25/100 = 25%\n\n• Common conversions:\n  - 50% = 1/2 = 0.5\n  - 25% = 1/4 = 0.25\n  - 10% = 1/10 = 0.1\n  - 75% = 3/4 = 0.75\n\n• Calculations:\n  - Finding percentage: What % is 15 of 50? Answer: 30%\n  - Finding amount: What is 20% of 80? Answer: 16\n  - Finding total: 40% of what number is 20? Answer: 50\n\n• Real applications:\n  - Discounts and sales\n  - Tips and tax\n  - Grades and scores\n  - Interest rates\n\nPercentages are used everywhere in daily life.`
                },
                'exponents': {
                    keywords: ['exponent', 'power', 'square', 'cube', 'exponential'],
                    response: `Exponents show how many times a number multiplies itself.\n\n• Notation: a^n (read as "a to the power of n")\n  - Base: the number being multiplied\n  - Exponent: how many times to multiply\n  - Example: 2³ = 2 × 2 × 2 = 8\n\n• Common exponents:\n  - Squared (²): multiply by itself twice\n  - Cubed (³): multiply by itself three times\n  - Negative exponents: 2^(-1) = 1/2\n\n• Exponent rules:\n  - a^m × a^n = a^(m+n)\n  - a^m ÷ a^n = a^(m-n)\n  - (a^m)^n = a^(mn)\n  - a^0 = 1 (any number to power 0)\n\n• Applications:\n  - Scientific notation (very large/small numbers)\n  - Growth and decay (bacteria, radioactive materials)\n  - Compound interest\n\nExponents are essential for higher mathematics.`
                }
            }
        };

        // Image analysis knowledge
        const imageKeywords = {
            'equation': ['formula', 'math', '=', '+', '-', '×', '÷', 'x', 'y', 'solve'],
            'graph': ['chart', 'plot', 'axis', 'line', 'curve', 'data'],
            'geometry': ['triangle', 'circle', 'square', 'shape', 'angle', 'line'],
            'historical': ['building', 'temple', 'wall', 'ancient', 'statue', 'artifact', 'dynasty', 'emperor', 'palace'],
            'diagram': ['diagram', 'illustration', 'schematic', 'drawing', 'structure'],
            'text': ['text', 'writing', 'document', 'page', 'book', 'note']
        };

        // DOM elements
        const messagesContainer = document.getElementById('messagesContainer');
        const userInput = document.getElementById('userInput');
        const sendBtn = document.getElementById('sendBtn');
        const uploadBtn = document.getElementById('uploadBtn');
        const imageInput = document.getElementById('imageInput');
        const previewContainer = document.getElementById('previewContainer');

        let currentImageData = null;

        // Image upload handler
        uploadBtn.addEventListener('click', () => {
            imageInput.click();
        });

        imageInput.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = (event) => {
                    currentImageData = event.target.result;
                    
                    // Show preview
                    previewContainer.innerHTML = `
                        <div class="preview-container">
                            <img src="${currentImageData}" class="upload-preview" alt="Uploaded image">
                            <button class="preview-remove" onclick="removeImage()">×</button>
                        </div>
                    `;
                    
                    userInput.placeholder = "Ask about this image...";
                };
                reader.readAsDataURL(file);
            }
        });

        function removeImage() {
            currentImageData = null;
            imageInput.value = '';
            previewContainer.innerHTML = '';
            userInput.placeholder = "Ask me anything or describe the image...";
        }

        // Analyze image content
        function analyzeImage(imageSrc) {
            // Simulate image analysis by checking for patterns
            let analysis = "📸 Image Analysis:\n\n";
            
            // Create a canvas to analyze image
            const img = new Image();
            img.src = imageSrc;
            img.onload = function() {
                // Get image dimensions to estimate content
                const width = img.width;
                const height = img.height;
                
                // Basic heuristics for image type
                let detectedType = 'general content';
                
                // Check aspect ratio and size for clues
                if (width > height * 1.5) {
                    detectedType = 'possibly a graph or wide diagram';
                } else if (height > width * 1.5) {
                    detectedType = 'possibly a tall document or portrait';
                } else {
                    detectedType = 'possibly a square image or photo';
                }
                
                return analysis + `Detected: ${detectedType}\n\nPlease describe what you see or ask a specific question about the image, and I'll help you analyze it!`;
            };
            
            // For now, return a generic response
            return analysis + `I can see an image has been uploaded!\n\nPlease tell me:\n• What's in the image?\n• Is it a math problem, historical photo, diagram, or something else?\n• What would you like to know about it?\n\nThen I can provide detailed analysis and answers!`;
        }

        // Find answer in knowledge base
        function findAnswer(question, hasImage = false) {
            const questionLower = question.toLowerCase();
            let bestMatch = null;
            let highestScore = 0;

            // Search through knowledge base
            for (let category in knowledgeBase) {
                for (let topic in knowledgeBase[category]) {
                    const data = knowledgeBase[category][topic];
                    let score = 0;

                    for (let keyword of data.keywords) {
                        if (questionLower.includes(keyword)) {
                            score += 100;
                        }
                    }

                    if (score > highestScore) {
                        highestScore = score;
                        bestMatch = data;
                    }
                }
            }

            // Check for math problem solving
            if (questionLower.includes('solve') || questionLower.includes('calculate')) {
                const mathAnswer = solveMathProblem(question);
                if (mathAnswer) {
                    return mathAnswer;
                }
            }

            return bestMatch ? bestMatch.response : null;
        }

        // Math problem solver
        function solveMathProblem(question) {
            const q = question.toLowerCase();

            // Simple algebra solver
            if (q.includes('solve:') || q.includes('solve')) {
                const match = question.match(/(\d+)x\s*\+\s*(\d+)\s*=\s*(\d+)/i) || 
                            question.match(/(\d+)x\s*-\s*(\d+)\s*=\s*(\d+)/i);
                
                if (match) {
                    const a = parseFloat(match[1]);
                    const b = parseFloat(match[2]);
                    const c = parseFloat(match[3]);
                    const x = (c - b) / a;
                    return `Solving the equation:\n\n${match[0]}\n\nStep 1: ${a}x = ${c} - ${b} = ${c - b}\nStep 2: x = ${c - b} / ${a}\n\n✅ Answer: x = ${x}`;
                }
            }

            // Basic arithmetic
            if (q.includes('+') || q.includes('-') || q.includes('×') || q.includes('*') || q.includes('÷') || q.includes('/')) {
                try {
                    let expression = question.replace(/×/g, '*').replace(/÷/g, '/');
                    const numberMatch = expression.match(/[\d\.\+\-\*\/\(\)]+/);
                    if (numberMatch) {
                        const result = eval(numberMatch[0]);
                        return `Calculation: ${numberMatch[0]}\n\n✅ Answer: ${result}`;
                    }
                } catch (e) {
                    return null;
                }
            }

            return null;
        }

        // Add message to chat
        function addMessage(text, sender, imageData = null) {
            const messageDiv = document.createElement('div');
            messageDiv.className = `message ${sender}`;
            
            const contentDiv = document.createElement('div');
            contentDiv.className = 'message-content';
            contentDiv.textContent = text;
            
            messageDiv.appendChild(contentDiv);
            
            if (imageData && sender === 'user') {
                const img = document.createElement('img');
                img.src = imageData;
                img.className = 'message-image';
                messageDiv.appendChild(img);
            }
            
            messagesContainer.appendChild(messageDiv);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }

        // Show loading indicator
        function showLoadingIndicator() {
            const messageDiv = document.createElement('div');
            messageDiv.className = 'message ai';
            messageDiv.id = 'loadingIndicator';
            
            const loadingDiv = document.createElement('div');
            loadingDiv.className = 'loading';
            loadingDiv.innerHTML = '<span></span><span></span><span></span>';
            
            messageDiv.appendChild(loadingDiv);
            messagesContainer.appendChild(messageDiv);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }

        // Remove loading indicator
        function removeLoadingIndicator() {
            const loading = document.getElementById('loadingIndicator');
            if (loading) {
                loading.remove();
            }
        }

        // Send message function
        function sendMessage() {
            const message = userInput.value.trim();
            if (!message && !currentImageData) return;

            // Add user message
            if (message) {
                addMessage(message, 'user', currentImageData);
            } else if (currentImageData) {
                addMessage('📸 Uploaded image', 'user', currentImageData);
            }

            userInput.value = '';
            sendBtn.disabled = true;

            // Show loading
            showLoadingIndicator();

            // Simulate processing
            setTimeout(() => {
                removeLoadingIndicator();
                
                let answer = null;

                if (currentImageData && !message) {
                    // Analyze the uploaded image
                    answer = analyzeImage(currentImageData);
                } else if (currentImageData && message) {
                    // User asked about the image
                    answer = findAnswer(message) || analyzeImage(currentImageData);
                } else {
                    // Regular question
                    answer = findAnswer(message);
                }
                
                if (answer) {
                    addMessage(answer, 'ai');
                } else {
                    addMessage(`I'm not sure about that. I can help with:\n\n📖 Chinese History - Dynasties, emperors, events\n📐 Math - Algebra, geometry, calculus, and more\n📸 Image Analysis - Upload photos of math problems or historical items\n\nTry asking about the Ming Dynasty or uploading a math problem!`, 'ai');
                }
                
                // Clear image after processing
                removeImage();
                sendBtn.disabled = false;
                userInput.focus();
            }, 500);
        }

        // Event listeners
        sendBtn.addEventListener('click', sendMessage);
        userInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });

        // Quick question function
        function askQuestion(question) {
            userInput.value = question;
            sendMessage();
        }

        userInput.focus();
    </script>
</body>
</html>
