<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>AI Tutor - History & Math</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            width: 100%;
            max-width: 700px;
            height: 90vh;
            max-height: 800px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            text-align: center;
            font-size: 24px;
            font-weight: bold;
        }

        .messages {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .message {
            display: flex;
            animation: slideIn 0.3s ease-out;
        }

        .message.user {
            justify-content: flex-end;
        }

        .message.ai {
            justify-content: flex-start;
        }

        .bubble {
            max-width: 70%;
            padding: 12px 16px;
            border-radius: 12px;
            word-wrap: break-word;
            line-height: 1.5;
            font-size: 14px;
        }

        .message.user .bubble {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .message.ai .bubble {
            background: #f0f0f0;
            color: #333;
        }

        .message-image {
            max-width: 100%;
            max-height: 250px;
            border-radius: 8px;
            margin-top: 8px;
        }

        .input-area {
            border-top: 1px solid #e0e0e0;
            padding: 16px;
            display: flex;
            gap: 10px;
            background: white;
        }

        .input-area input {
            flex: 1;
            border: 1px solid #ddd;
            border-radius: 24px;
            padding: 12px 16px;
            font-size: 14px;
            outline: none;
        }

        .input-area input:focus {
            border-color: #667eea;
        }

        .btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            cursor: pointer;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .btn:hover {
            transform: scale(1.05);
        }

        input[type="file"] {
            display: none;
        }

        .preview {
            width: 50px;
            height: 50px;
            border-radius: 8px;
            object-fit: cover;
            border: 2px solid #ddd;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">📚 AI Tutor - 📸 Images + 📖 History + 📐 Math</div>
        
        <div class="messages" id="messages">
            <div class="message ai">
                <div class="bubble">👋 Hi! I'm your AI tutor!<br><br>I can help with:<br>📖 Chinese History<br>📐 Math<br>📸 Image Analysis<br><br>What would you like to learn?</div>
            </div>
        </div>
        
        <div class="input-area">
            <button class="btn" onclick="document.getElementById('fileInput').click()">📸</button>
            <input type="file" id="fileInput" accept="image/*">
            <img id="preview" class="preview" style="display:none;">
            <input type="text" id="input" placeholder="Ask me anything...">
            <button class="btn" onclick="send()">➤</button>
        </div>
    </div>

    <script>
        const knowledgeBase = {
            'ming dynasty': 'The Ming Dynasty (1368-1644) was one of China\'s greatest periods. Known for the Forbidden City and Great Wall renovations. Famous for art, literature, and porcelain. Zheng He led massive maritime expeditions. Declined due to political instability.',
            'great wall': 'The Great Wall of China is iconic. Construction began in 7th century BC. Primary purpose: Defense against invasions. Over 13,000 miles long. Most famous sections built during Ming Dynasty. Symbol of Chinese civilization.',
            'forbidden city': 'The Forbidden City is the imperial palace of Chinese emperors. Located in Beijing. Built in 1406 during Ming Dynasty. Took 14 years with over 1 million workers. Covers 178 acres with 980 buildings. Now a UNESCO World Heritage Site.',
            'tang dynasty': 'The Tang Dynasty (618-907) was the "Golden Age" of Chinese civilization. Greatest territorial expansion of Imperial China. Cultural peak with poetry, art, and music. Capital: Chang\'an (Xi\'an). Trade flourished on the Silk Road.',
            'song dynasty': 'The Song Dynasty (960-1279) had remarkable technological advancement. Peak of landscape painting and ceramics. Invented printing, gunpowder, and navigation tools. Economic prosperity with flourishing trade. First paper money system.',
            'qin dynasty': 'The Qin Dynasty (221-206 BC) was the first unified Chinese empire. Founded by Qin Shi Huang. Created the Terracotta Army. Built early Great Wall sections. Standardized measurements and currency. Short but highly influential.',
            'silk road': 'The Silk Road was a network of trade routes connecting East and West. Active from 2nd century BC to 15th century. Named after valuable silk trade. Connected China, Central Asia, India, Mediterranean. Also facilitated cultural exchange.',
            'zheng he': 'Zheng He was a famous Chinese admiral (1371-1433). Led seven major naval expeditions. Commanded massive treasure fleets with 300+ ships. Voyages reached Africa, Arabia, Indian Ocean. Promoted trade and diplomacy.',
            'confucius': 'Confucius (551-479 BC) was an influential philosopher. Focused on ethics, morality, and relationships. Key concepts: filial piety, respect, harmony. His teachings influenced Chinese culture for 2,500+ years.',
            'algebra': 'Algebra deals with equations and variables. Uses letters to represent unknown numbers. Key concepts: linear equations (ax+b=c), quadratic equations, polynomials. Real applications in physics, engineering, economics.',
            'geometry': 'Geometry studies shapes and spatial properties. Key shapes: triangles, circles, squares. Important: area, perimeter, volume, Pythagorean theorem. Triangle area = ½ × base × height. Circle area = πr².',
            'calculus': 'Calculus studies change and motion. Two branches: Differential (derivatives) and Integral (integrals). Key concepts: limits, rates of change, accumulation. Applications in physics, engineering, economics.',
            'statistics': 'Statistics analyzes data. Key concepts: mean, median, mode, range, standard deviation. Data types: quantitative, qualitative, discrete, continuous. Probability = favorable outcomes / total outcomes.',
            'trigonometry': 'Trigonometry studies angles and sides in triangles. Main functions: sine, cosine, tangent (SOH-CAH-TOA). Key angles: 0°, 30°, 45°, 60°, 90°. Applications in navigation, engineering, physics.',
            'fractions': 'Fractions represent parts of a whole. Numerator (top), denominator (bottom). Operations: addition/subtraction need same denominator, multiplication, division by reciprocal. Example: 3/4 means 3 out of 4 parts.',
            'percentage': 'Percentages express numbers as parts of 100. Formula: (part/whole) × 100. Common: 50%=0.5, 25%=0.25, 10%=0.1. Applications: discounts, tax, grades, interest.',
            'exponents': 'Exponents show repeated multiplication. 2³ = 2×2×2 = 8. Rules: a^m × a^n = a^(m+n), a^0 = 1. Applications: scientific notation, growth/decay, compound interest.'
        };

        let currentImage = null;

        document.getElementById('fileInput').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(event) {
                    currentImage = event.target.result;
                    document.getElementById('preview').src = currentImage;
                    document.getElementById('preview').style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        });

        function send() {
            const input = document.getElementById('input').value.trim();
            if (!input && !currentImage) return;

            // Show user message
            if (input || currentImage) {
                const msg = document.createElement('div');
                msg.className = 'message user';
                let content = '<div class="bubble">' + (input || '📸 Image') + '</div>';
                if (currentImage) {
                    content += '<img src="' + currentImage + '" class="message-image">';
                }
                msg.innerHTML = content;
                document.getElementById('messages').appendChild(msg);
            }

            document.getElementById('input').value = '';
            const preview = document.getElementById('preview');
            preview.style.display = 'none';
            currentImage = null;

            // Get answer
            setTimeout(() => {
                let answer = 'I can help with Chinese History, Math, or analyze images. Try asking about: Ming Dynasty, Great Wall, Tang Dynasty, Algebra, Geometry, Calculus, or upload a math problem image!';
                
                if (input) {
                    const lower = input.toLowerCase();
                    for (let key in knowledgeBase) {
                        if (lower.includes(key)) {
                            answer = knowledgeBase[key];
                            break;
                        }
                    }
                    
                    // Math solver
                    if (lower.includes('solve') || lower.includes('calculate')) {
                        const match = input.match(/(\d+)x\s*\+\s*(\d+)\s*=\s*(\d+)/i);
                        if (match) {
                            const a = parseFloat(match[1]);
                            const b = parseFloat(match[2]);
                            const c = parseFloat(match[3]);
                            const x = (c - b) / a;
                            answer = `Solving: ${match[0]}\n\nStep 1: ${a}x = ${c} - ${b} = ${c - b}\nStep 2: x = ${c - b} / ${a}\n\n✅ Answer: x = ${x}`;
                        }
                    }
                }

                // Show AI response
                const msg = document.createElement('div');
                msg.className = 'message ai';
                msg.innerHTML = '<div class="bubble">' + answer + '</div>';
                document.getElementById('messages').appendChild(msg);
                document.getElementById('messages').scrollTop = document.getElementById('messages').scrollHeight;
            }, 300);

            document.getElementById('messages').scrollTop = document.getElementById('messages').scrollHeight;
        }

        // Send on Enter
        document.getElementById('input').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') send();
        });

        document.getElementById('input').focus();
    </script>
</body>
</html>
